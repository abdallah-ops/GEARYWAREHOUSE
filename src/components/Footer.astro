---
// Newsletter signup is handled by the Audience Republic widget (campaign 15456).
// Our on-brand "join the list" button triggers a hidden AR signup widget,
// so the button keeps the site's styling and AR only renders the popup form.
---
<footer id="contact">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <img class="foot-logo" src="/assets/img/geary-logo.png" alt="Geary Warehouse" width="2000" height="350" />
        <p>209 geary avenue, toronto<br />toronto's home for the underground</p>
      </div>
      <div class="foot-col">
        <h4>visit</h4>
        <a href="https://maps.google.com/?q=209+Geary+Ave+Toronto" target="_blank" rel="noopener">209 geary ave &rarr;</a>
        <p>open late, event nights</p>
        <a href="mailto:gawp.events@gmail.com">gawp.events@gmail.com</a>
      </div>
      <div class="foot-col">
        <h4>on the list</h4>
        <p style="text-transform:none">first to know. nothing else.</p>
        <button type="button" class="news-btn" id="joinListBtn" aria-haspopup="dialog">join the list &rarr;</button>

        <!-- Hidden Audience Republic signup trigger (campaign 15456). The visible
             button above forwards its click here so AR opens its popup form. -->
        <div class="ar-hidden" aria-hidden="true">
          <div
            class="ar-register-button ar-widget-15456"
            data-campaign-oid="15456"
            data-widget-type="button"
            data-widget-color="#ff7a18"
            data-widget-text="Subscribe"
            data-signup-form="true"
          ></div>
        </div>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© 2026 geary avenue warehouse project</span>
      <a class="powered" href="https://aftrdark.ca" target="_blank" rel="noopener">powered by <b>aftr dark</b></a>
      <div class="socials">
        <a href="https://instagram.com/gearywarehouse" target="_blank" rel="noopener">instagram</a>
        <a href="https://soundcloud.com/gearyavewarehouseproject" target="_blank" rel="noopener">soundcloud</a>
        <a href="https://discord.com/invite/xvcbJp7vPZ" target="_blank" rel="noopener">discord</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  // Load the Audience Republic SDK once.
  (function (id) {
    if (document.getElementById(id)) return;
    var s = document.createElement('script');
    s.id = id;
    s.src = 'https://sdk-cdn.arep.co/prod/v1.0.7/sdk.min.js';
    s.async = true;
    document.head.appendChild(s);
  })('ar-jssdk');

  // Forward the on-brand "join the list" button to the hidden AR trigger,
  // so AR opens its signup popup while our button keeps the site styling.
  document.addEventListener('click', function (e) {
    var btn = e.target.closest && e.target.closest('#joinListBtn');
    if (!btn) return;
    e.preventDefault();
    var ar =
      document.querySelector('.ar-widget-15456.ar-register-button') ||
      document.querySelector('.ar-widget-15456');
    if (ar) ar.click();
  });
</script>
