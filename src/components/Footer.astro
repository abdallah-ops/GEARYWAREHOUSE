---
// Newsletter signup (Audience Republic, campaign 15456). On-brand button links
// to the AR signup form. NOTE: the "newsletteer" double-e is a DELIBERATE part of
// the real URL — do not "correct" it.
// To make this a true in-page popup styled like the site, see note in chat:
// paste the AR "Embedded form" embed code and we'll mount it in a styled modal.
const NEWSLETTER_URL = 'https://arep.co/m/join-our-newsletteer';
---
<footer id="contact">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <img class="foot-logo" src="/assets/img/geary-logo.png" alt="Geary Warehouse" width="2000" height="350" />
        <p>209 geary avenue, toronto<br />toronto's home for the underground</p>
      </div>
      <div class="foot-col">
        <h4>visit</h4>
        <a href="https://maps.google.com/?q=209+Geary+Ave+Toronto" target="_blank" rel="noopener">209 geary ave &rarr;</a>
        <p>open late, event nights</p>
        <a href="mailto:gawp.events@gmail.com">gawp.events@gmail.com</a>
      </div>
      <div class="foot-col">
        <h4>on the list</h4>
        <p style="text-transform:none">first to know. nothing else.</p>
        <a class="news-btn" href={NEWSLETTER_URL} target="_blank" rel="noopener">join the list &rarr;</a>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© 2026 geary avenue warehouse project</span>
      <a class="powered" href="https://aftrdark.ca" target="_blank" rel="noopener">powered by <b>aftr dark</b></a>
      <div class="socials">
        <a href="https://instagram.com/gearywarehouse" target="_blank" rel="noopener">instagram</a>
        <a href="https://soundcloud.com/gearyavewarehouseproject" target="_blank" rel="noopener">soundcloud</a>
        <a href="https://discord.com/invite/xvcbJp7vPZ" target="_blank" rel="noopener">discord</a>
      </div>
