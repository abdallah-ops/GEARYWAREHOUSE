---
const BOOK_EMAIL = 'gawp.events@gmail.com';
---
<header>
  <div class="wrap nav">
    <a href="#top" aria-label="Geary Warehouse — home">
      <img class="brand-logo" src="/assets/img/geary-logo.png" alt="Geary Warehouse" width="2000" height="350" />
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="#events">events</a><span aria-hidden="true">/</span>
      <a href="#room">the room</a><span aria-hidden="true">/</span>
      <a href="#book">book it</a><span aria-hidden="true">/</span>
      <a href="#contact">find us</a>
      <a href="#events" class="nav-cta">tickets</a>
    </nav>
    <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="mobileMenu" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="mobile-menu" id="mobileMenu" aria-label="Mobile">
    <a href="#events">events</a>
    <a href="#room">the room</a>
    <a href="#book">book it</a>
    <a href="#contact">find us</a>
    <a href="#events" class="mobile-cta">tickets &rarr;</a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('mobileMenu');
  if (toggle && menu) {
    const close = () => {
      menu.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
    };
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    });
    // Close after tapping a link, or on Escape.
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
</script>
